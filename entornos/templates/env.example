# Environment file for the generated Odoo dev stack.
# Rendered by bootstrap.sh to `.env` (real values, gitignored — NEVER commit)
# and `.env.example` (committable reference, password masked).

# --- Identity ----------------------------------------------------------------
# Used to namespace container + volume so multiple projects coexist.
ODOO_DEVELOPER=__DEVELOPER__
ODOO_PROJECT_NAME=__PROJECT__
ODOO_VERSION=__VERSION__

# --- Ports (host side) ---------------------------------------------------------
# Defaults per version XX: web 80XX, longpoll 90XX, debug 30XX.
ODOO_PORT=__PORT__
ODOO_LONGPOLL_PORT=__LONGPOLL_PORT__
ODOO_DEBUG_PORT=__DEBUG_PORT__

# --- Database ------------------------------------------------------------------
# compose mode: host is the sibling `db` service.
# external mode: host was given via --db-host (no hardcoded IP defaults,
# audit gotcha 5).
DB_PORT_5432_TCP_ADDR=__DB_HOST__
DB_PORT_5432_TCP_PORT=5432
DB_ENV_POSTGRES_USER=__DB_USER__
DB_ENV_POSTGRES_PASSWORD=__DB_PASSWORD__

# --- Optional Enterprise sources (read-only mount) -----------------------------
# Set with bootstrap.sh --enterprise-path, or uncomment manually together with
# the #ENTERPRISE# line in docker-compose.yml.
# ENTERPRISE_PATH=/absolute/path/to/enterprise
