# Copiar a .env y ajustar. Los secretos NUNCA se versionan.
# Ruta local a las fuentes enterprise de Odoo (NO están en este repo).
ENTERPRISE_PATH=/ruta/a/odoo/enterprise

# Versión de la imagen Odoo del gestor.
ODOO_VERSION=19.0

# Puertos publicados en el host.
ODOO_PORT=8169
ODOO_GEVENT_PORT=8172

# Credenciales del Postgres dedicado del gestor.
POSTGRES_USER=odoo
POSTGRES_PASSWORD=cambiar-esta-password
