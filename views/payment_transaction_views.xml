<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_transaction_form" model="ir.ui.view">
        <field name="name">Azul Transaction Form</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <group name="transaction_details" position="after">
                <group string="Azul" name="azul_details"
                       invisible="provider_code != 'azul'">
                    <field name="azul_order_id"/>
                    <field name="azul_authorization_code"/>
                    <field name="azul_rrn"/>
                    <field name="azul_iso_code"/>
                    <field name="azul_response_message"/>
                    <field name="azul_date_time"/>
                    <field name="azul_amount_sent"/>
                    <field name="azul_itbis_sent"/>
                    <field name="azul_conversion_details"/>
                </group>
            </group>
        </field>
    </record>

</odoo>
